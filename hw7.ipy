# In[41]:


#按照題目生成 n(1,1) ，並連加直到>5 or <-5
import numpy as np
def getS():    
    a=[]
    while True:
        X=np.random.normal(1,1)
        a.append(X)
        if sum(a)>5 or sum(a)<-5:
            return sum(a)
            break 


# In[42]:


getS()


# In[43]:


#模擬1000000次
list=[]
for i in range(1000000):
    list.append(getS())


# In[ ]:





# In[44]:


#compute p ，用蒙地卡羅法，1000000 僅出現13次 <-5 。機率趨近於0
for i in range(1000000):
    if list[i]<-5:
        list[i]=1
    else:
        list[i]=0

        
print(sum(list))
p=sum(list)/1000000
print(p)


# In[45]:


#改從N(-1,1)生成
def getS():    
    a=[]
    while True:
        X=np.random.normal(-1,1)
        a.append(X)
        if sum(a)>5 or sum(a)<-5:
            return sum(a)
            break 


# In[46]:


#P(SN<-5) 機率大幅度提高
list=[]
for i in range(1000000):
    list.append(getS())


# In[ ]:





# In[47]:


#建立 I==1 when s<-5        I==0 ow
b=[]
for i in range(1000000):
    if list[i]<-5:
        b.append(1)
    else:
        b.append(0)
        
        


# In[48]:


#變得好取得後，要重新修正機率，用加權方式。經過課本的公式， p(sn<-5)==I * e**(2sn)
list=np.array(list)
b=np.array(b)
c=(np.exp(2*list))*b


# In[49]:


c


# In[50]:


#計算 p(sn<-5) ，結果也是趨近0
P=sum(c)/1000000
print(P)


