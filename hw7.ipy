# In[1]:


#按照題目生成兩個時間  poisson process lambda=2 到達時間點  服務時間長 exp=1
import random
import math
import numpy as np
from scipy.stats import sem
a_time=[]
s_time=[]
t=0
I=0

for i in range(10):
    u=random.uniform(0,1)
    t=t-(0.5*math.log(u))
    a_time.append(t)
    s_time.append(-math.log(u))
    


# In[2]:


a_time #生成10人到達時間點 poisson process lambda=2


# In[3]:


s_time #生成10人服務時間長 exp=1


# In[4]:


#第1人不需要等待 ， 花費時間T=服務時間
T=[]
T.append(s_time[0])
T


# In[5]:


#第一人結束時間點，等於第一人到達時間+第一人服務時間
F=[]
F.append(s_time[0]+a_time[0])
F


# In[6]:


#計算每個人的結束時間點，若到達時，前面的人還沒做完，必須等前面做完，Fi=Fi-1+si。 前面的人已做完，可直接開始。 Fi=ai+si

for i in range(1,10):
    if a_time[i]<=F[i-1]:
        time=F[i-1]+s_time[i]
        F.append(time)
    else:
        time=s_time[i]+a_time[i]
        F.append(time)


# In[7]:


F


# In[8]:


#每個人花費時間T=完成時間點-到達時間點
import numpy as np
F=np.array(F)
a_time=np.array(a_time)
T=F-a_time


# In[9]:


T #得出T1.....T10


# In[10]:


#計算i到達時在系統內人數，比較arrival time跟前面人的f time ，若i到達時，前面[0:i]人還沒做完 ，回傳true 並count true。
d=[0]
for i in range(1,10):
    b=a_time[i]<F[0:i]
    num=(b == True).sum()
    d.append(num)
print(d)


# In[11]:


#-------------------------------------------------------------------------


# In[12]:


#將前面過程函數化，方便模擬。
def get_T(x):
    a_time=[]
    s_time=[]
    a_time2=[]
    s_time2=[]
    t=0
    t2=0
    for i in range(10):
        u=random.uniform(0,1)
        u2=1-u #antithetic  改用1-u生成
        t=t-(0.5*math.log(u))
        a_time.append(t)
        s_time.append(-math.log(u))
        t2=t2-(0.5*math.log(u2))
        a_time2.append(t2)
        s_time2.append(-math.log(u2))
        
        
    T=[]
    T.append(s_time[0])
    F=[]
    F.append(s_time[0]+a_time[0]) 
    
    for i in range(1,10):
        if a_time[i]<=F[i-1]:
            time=F[i-1]+s_time[i]
            F.append(time)
        else:
            time=s_time[i]+a_time[i]
            F.append(time)
    
    F=np.array(F)
    a_time=np.array(a_time)
    T=F-a_time
    
    #antithetic  
    T2=[]
    T2.append(s_time2[0])
    F2=[]
    F2.append(s_time2[0]+a_time2[0]) 
    
    for i in range(1,10):
        if a_time2[i]<=F2[i-1]:
            time2=F2[i-1]+s_time2[i]
            F2.append(time2)
        else:
            time2=s_time2[i]+a_time2[i]
            F2.append(time2)
    
    F2=np.array(F2)
    a_time2=np.array(a_time2)
    T2=F2-a_time2
    
    
    
    #回傳每次模擬的sum s
    s=sum(s_time)
    
    #回傳每次模擬的s-I 。I間格時間，等於最後一人到達-第一人到達
    I=a_time[-1]-a_time[0]
    y=s-I
    
    
    #compute d
    d=[0] #第一人前方沒有人，
    for i in range(1,10):
        b=a_time[i]<F[0:i]
        num=(b == True).sum()
        d.append(num)
    
    
    
    return T,s,y,d,T2
    


# In[13]:


get_T(1)


# In[14]:


sim=[]
for i in range(100):
    sim.append(get_T(i))


# In[15]:


sim[0]


# In[16]:


# compute raw t1+....t10


# In[17]:


T=[]
for i in range(100):
    T.append(sim[i][0])


# In[18]:


result=[]

for i in range (len(T)):
    a=np.sum(T[i])
    result.append(a)


# In[ ]:





# In[19]:


#raw result
E_X =np.sum(result)/100

R_var=np.var(result)

print(E_X,R_var)


# In[20]:


#antithetic 
T2=[]
for i in range(100):
    T2.append(sim[i][4])


# In[21]:


result2=[]

for i in range (len(T2)):
    a=np.sum(T2[i])
    result2.append(a)


# In[ ]:





# In[22]:


#(x+y)/2  x=用u生成的t1+...t10  y=用1-u生成的t1+...t10
anti=(np.array(result)+np.array(result2))/2


# In[23]:


#antithetic result  var((x+y)/2)
E_X =np.sum(anti)/100

R_var=np.var(anti)

print(E_X,R_var)


# In[24]:


# Q3 先取出100個sums
sums=[]
for i in range(100):
    sums.append(sim[i][1])


# In[ ]:





# In[ ]:





# In[ ]:





# In[25]:


#求平均
usums=sum(sums)/100


# In[ ]:





# In[26]:


#compute c = cov(x,y)/var(y)


# In[27]:


c=-np.cov(result,sums)[0][1]/np.cov(result,sums)[1][1]

print(c)


# In[28]:


#new = x-c*(y-uy)    ，x=t1+...t10 , y=sums  (control variate)
new=[]
for i in range(100):
    X=result[i]+c*(sums[i]-usums)
    new.append(X)


# In[ ]:





# In[29]:


#Q3 result 
E_X =np.sum(new)/100

var2=np.var(new)

print(E_X,var2)


# In[30]:


# Q4 取出100個 S-I
IS=[]
for i in range(100):
    IS.append(sim[i][2])


# In[ ]:





# In[31]:


#求平均
Isum=sum(IS)/100


# In[32]:


#compute c
c=-np.cov(result,IS)[0][1]/np.cov(result,IS)[1][1]
print(c)


# In[33]:


#算出x-c*(y-uy)    ，x=t1+...t10 , y=i-s (control variate)
new=[]
for i in range(100):
    X=result[i]+c*(IS[i]-Isum)
    new.append(X)


# In[34]:


#Q4 result
E_X =np.sum(new)/100

var2=np.var(new)

print(E_X,var2)


